<UserControl x:Class="CleanWipe.App.Views.PreScanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CleanWipe.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:PreScanViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             RenderTransformOrigin="0.5,0.5">
    <UserControl.RenderTransform>
        <TranslateTransform X="0" />
    </UserControl.RenderTransform>
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource ViewEnter}" />
        </EventTrigger>
    </UserControl.Triggers>

    <UserControl.Resources>
        <!-- Plantilla de ítem de rastro -->
        <DataTemplate x:Key="TraceItemTemplate">
            <Border Padding="10,7" Margin="0,2" CornerRadius="8" Background="#B8FFFFFF"
                    BorderBrush="#D9FFFFFF" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" Style="{StaticResource CleanCheckBox}"
                              IsChecked="{Binding IsIncluded}"
                              IsEnabled="{Binding IsSystemProtected, Converter={StaticResource InvBool}}"
                              VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" FontFamily="Segoe MDL2 Assets"
                               Text="{Binding Type, Converter={StaticResource TraceIcon}}" FontSize="14"
                               Foreground="{StaticResource AccentHoverBrush}" VerticalAlignment="Center" Margin="12,0,10,0" />
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Path}" Style="{StaticResource MonoPath}" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Description}" Style="{StaticResource Caption}" />
                            <TextBlock Text="{Binding SkipReason}" Style="{StaticResource Caption}"
                                       Foreground="{StaticResource AccentDangerBrush}" Margin="8,0,0,0"
                                       Visibility="{Binding SkipReason, Converter={StaticResource StrToVis}}" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Grid.Column="3" Text="{Binding SizeReadable}" Style="{StaticResource Caption}"
                               VerticalAlignment="Center" Margin="10,0,0,0" />
                </Grid>
            </Border>
        </DataTemplate>

        <Style x:Key="GroupExpander" TargetType="Expander">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="IsExpanded" Value="True" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="32,24,32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Style="{StaticResource CaptionButton}" Width="40" Height="40"
                    FontSize="16" Content="&#xE72B;" Command="{Binding BackCommand}" VerticalAlignment="Top" Margin="0,4,14,0" />
            <StackPanel Grid.Column="1">
                <TextBlock Text="{Binding Program.Name}" Style="{StaticResource DisplayTitle}" FontSize="26"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="Análisis pre-desinstalación · revisa y ajusta lo que se eliminará"
                           Style="{StaticResource BodySecondary}" Margin="0,2,0,0" />
            </StackPanel>
        </Grid>

        <!-- Cuerpo -->
        <Grid Grid.Row="1" Margin="0,18,0,0">
            <!-- Scanning -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE895;" FontSize="34"
                           Foreground="{StaticResource AccentPrimaryBrush}" HorizontalAlignment="Center"
                           RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform><RotateTransform /></TextBlock.RenderTransform>
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                     From="0" To="360" Duration="0:0:1" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
                <TextBlock Text="Buscando rastros en disco y registro..." Style="{StaticResource BodySecondary}"
                           Margin="0,14,0,0" HorizontalAlignment="Center" />
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                <StackPanel Margin="0,0,8,0">
                    <Expander Style="{StaticResource GroupExpander}" Visibility="{Binding Folders.Count, Converter={StaticResource CountToVis}}">
                        <Expander.Header><TextBlock Style="{StaticResource Subtitle}" FontSize="15"><Run Text="Carpetas"/> <Run Text="(" /><Run Text="{Binding Folders.Count, Mode=OneWay}" /><Run Text=")" /></TextBlock></Expander.Header>
                        <ItemsControl ItemsSource="{Binding Folders}" ItemTemplate="{StaticResource TraceItemTemplate}" Margin="0,6,0,0" />
                    </Expander>
                    <Expander Style="{StaticResource GroupExpander}" Visibility="{Binding RegistryKeys.Count, Converter={StaticResource CountToVis}}">
                        <Expander.Header><TextBlock Style="{StaticResource Subtitle}" FontSize="15"><Run Text="Claves de registro"/> <Run Text="(" /><Run Text="{Binding RegistryKeys.Count, Mode=OneWay}" /><Run Text=")" /></TextBlock></Expander.Header>
                        <ItemsControl ItemsSource="{Binding RegistryKeys}" ItemTemplate="{StaticResource TraceItemTemplate}" Margin="0,6,0,0" />
                    </Expander>
                    <Expander Style="{StaticResource GroupExpander}" Visibility="{Binding Files.Count, Converter={StaticResource CountToVis}}">
                        <Expander.Header><TextBlock Style="{StaticResource Subtitle}" FontSize="15"><Run Text="Archivos"/> <Run Text="(" /><Run Text="{Binding Files.Count, Mode=OneWay}" /><Run Text=")" /></TextBlock></Expander.Header>
                        <ItemsControl ItemsSource="{Binding Files}" ItemTemplate="{StaticResource TraceItemTemplate}" Margin="0,6,0,0" />
                    </Expander>
                    <Expander Style="{StaticResource GroupExpander}" Visibility="{Binding Shortcuts.Count, Converter={StaticResource CountToVis}}">
                        <Expander.Header><TextBlock Style="{StaticResource Subtitle}" FontSize="15"><Run Text="Accesos directos"/> <Run Text="(" /><Run Text="{Binding Shortcuts.Count, Mode=OneWay}" /><Run Text=")" /></TextBlock></Expander.Header>
                        <ItemsControl ItemsSource="{Binding Shortcuts}" ItemTemplate="{StaticResource TraceItemTemplate}" Margin="0,6,0,0" />
                    </Expander>
                    <Expander Style="{StaticResource GroupExpander}" Visibility="{Binding Services.Count, Converter={StaticResource CountToVis}}">
                        <Expander.Header><TextBlock Style="{StaticResource Subtitle}" FontSize="15"><Run Text="Servicios"/> <Run Text="(" /><Run Text="{Binding Services.Count, Mode=OneWay}" /><Run Text=")" /></TextBlock></Expander.Header>
                        <ItemsControl ItemsSource="{Binding Services}" ItemTemplate="{StaticResource TraceItemTemplate}" Margin="0,6,0,0" />
                    </Expander>
                    <Expander Style="{StaticResource GroupExpander}" Visibility="{Binding Tasks.Count, Converter={StaticResource CountToVis}}">
                        <Expander.Header><TextBlock Style="{StaticResource Subtitle}" FontSize="15"><Run Text="Tareas programadas"/> <Run Text="(" /><Run Text="{Binding Tasks.Count, Mode=OneWay}" /><Run Text=")" /></TextBlock></Expander.Header>
                        <ItemsControl ItemsSource="{Binding Tasks}" ItemTemplate="{StaticResource TraceItemTemplate}" Margin="0,6,0,0" />
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Barra de resumen / acción -->
        <Border Grid.Row="2" Style="{StaticResource GlassCard}" Margin="0,16,0,20" Padding="22,16"
                Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Summary}" Style="{StaticResource Subtitle}" FontSize="16" />
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="Seleccionar:" Style="{StaticResource Caption}" VerticalAlignment="Center" />
                        <Button Content="todo" Style="{StaticResource GhostButton}" Padding="10,3" Margin="8,0,0,0"
                                FontSize="12" Command="{Binding SelectAllCommand}" />
                        <Button Content="nada" Style="{StaticResource GhostButton}" Padding="10,3" Margin="6,0,0,0"
                                FontSize="12" Command="{Binding SelectNoneCommand}" />
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="2" Style="{StaticResource PrimaryButton}" Command="{Binding StartUninstallCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center" />
                        <TextBlock Text="DESINSTALAR Y LIMPIAR" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
