<UserControl x:Class="CleanWipe.App.Views.ProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CleanWipe.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:ProgressViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             RenderTransformOrigin="0.5,0.5">
    <UserControl.RenderTransform>
        <TranslateTransform X="0" />
    </UserControl.RenderTransform>
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource ViewEnter}" />
        </EventTrigger>
    </UserControl.Triggers>

    <Grid Margin="48,32,48,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,0">
            <TextBlock Text="Desinstalando" Style="{StaticResource BodySecondary}" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding ProgramName}" Style="{StaticResource DisplayTitle}" FontSize="26"
                       HorizontalAlignment="Center" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Porcentaje grande + glow -->
        <Grid Grid.Row="1" Margin="0,26,0,0" HorizontalAlignment="Center">
            <Ellipse Width="180" Height="180" Fill="#101A2E">
                <Ellipse.Effect>
                    <DropShadowEffect Color="#1E6FFF" BlurRadius="60" ShadowDepth="0" Opacity="0.4" />
                </Ellipse.Effect>
            </Ellipse>
            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"
                       FontFamily="{StaticResource DisplayFont}" FontWeight="Bold" FontSize="54"
                       Foreground="{StaticResource TextPrimaryBrush}">
                <Run Text="{Binding Percent, Mode=OneWay}" /><Run Text="%" FontSize="28" Foreground="{StaticResource TextSecondaryBrush}" />
            </TextBlock>
        </Grid>

        <!-- Barra + estado -->
        <StackPanel Grid.Row="1" VerticalAlignment="Bottom" Margin="0,0,0,-70">
            <ProgressBar Style="{StaticResource GlowProgressBar}" Maximum="100" Value="{Binding Percent}"
                         Width="520" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding StatusText}" Style="{StaticResource Body}" HorizontalAlignment="Center"
                       Margin="0,16,0,0" />
        </StackPanel>

        <!-- Lista de pasos completados -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,90,0,0" MaxWidth="640">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding CompletedSteps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Style="{StaticResource MonoPath}" Margin="0,3"
                                       TextTrimming="CharacterEllipsis">
                                <TextBlock.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </TextBlock.Triggers>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Button Grid.Row="3" Content="Cancelar" Style="{StaticResource GhostButton}" HorizontalAlignment="Center"
                Margin="0,16,0,0" Command="{Binding CancelCommand}"
                Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}" />
    </Grid>
</UserControl>
