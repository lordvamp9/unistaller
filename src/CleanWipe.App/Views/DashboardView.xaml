<UserControl x:Class="CleanWipe.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CleanWipe.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:DashboardViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             RenderTransformOrigin="0.5,0.5">
    <UserControl.RenderTransform>
        <TranslateTransform X="0" />
    </UserControl.RenderTransform>
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource ViewEnter}" />
        </EventTrigger>
    </UserControl.Triggers>

    <Grid Margin="32,24,32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Programas instalados" Style="{StaticResource DisplayTitle}" />
            <TextBlock Style="{StaticResource BodySecondary}" Margin="0,4,0,0">
                <Run Text="{Binding ResultCount, Mode=OneWay}" />
                <Run Text="programas · selecciona uno para analizar y eliminar por completo" />
            </TextBlock>
        </StackPanel>

        <!-- Buscador -->
        <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="18,6" Margin="0,20,0,0" Height="54">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" Text="&#xE721;" FontSize="18"
                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0" />
                <Grid Grid.Column="1">
                    <TextBlock Text="Buscar programa o fabricante..." Style="{StaticResource BodySecondary}"
                               VerticalAlignment="Center"
                               Visibility="{Binding SearchText, Converter={StaticResource StrToVis}, ConverterParameter=invert}" />
                    <TextBox Style="{StaticResource SearchBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </Grid>
        </Border>

        <!-- Filtros -->
        <ItemsControl Grid.Row="2" Margin="0,16,0,8">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <RadioButton Style="{StaticResource NavButton}" Content="Todos" GroupName="filter" Margin="0,0,8,0"
                         Command="{Binding SetFilterCommand}" CommandParameter="Todos"
                         IsChecked="{Binding ActiveFilter, Converter={StaticResource EqToBool}, ConverterParameter=Todos, Mode=OneWay}" />
            <RadioButton Style="{StaticResource NavButton}" Content="Con residuos" GroupName="filter" Margin="0,0,8,0"
                         Command="{Binding SetFilterCommand}" CommandParameter="Con residuos"
                         IsChecked="{Binding ActiveFilter, Converter={StaticResource EqToBool}, ConverterParameter='Con residuos', Mode=OneWay}" />
            <RadioButton Style="{StaticResource NavButton}" Content="Recientes" GroupName="filter" Margin="0,0,8,0"
                         Command="{Binding SetFilterCommand}" CommandParameter="Recientes"
                         IsChecked="{Binding ActiveFilter, Converter={StaticResource EqToBool}, ConverterParameter=Recientes, Mode=OneWay}" />
            <RadioButton Style="{StaticResource NavButton}" Content="Por tamaño" GroupName="filter"
                         Command="{Binding SetFilterCommand}" CommandParameter="Por tamaño"
                         IsChecked="{Binding ActiveFilter, Converter={StaticResource EqToBool}, ConverterParameter='Por tamaño', Mode=OneWay}" />
        </ItemsControl>

        <!-- Lista -->
        <Grid Grid.Row="3">
            <!-- Loading -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE895;" FontSize="34"
                           Foreground="{StaticResource AccentPrimaryBrush}" HorizontalAlignment="Center"
                           RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform><RotateTransform /></TextBlock.RenderTransform>
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                     From="0" To="360" Duration="0:0:1" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
                <TextBlock Text="Detectando programas instalados..." Style="{StaticResource BodySecondary}"
                           Margin="0,14,0,0" HorizontalAlignment="Center" />
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,4,0,0"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                <ItemsControl ItemsSource="{Binding ProgramsView}" Margin="0,0,8,16">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ProgramCard}">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.OpenProgramCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}" />
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Monograma -->
                                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="11"
                                            Background="{StaticResource BrandGradientBrush}" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE977;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource Body}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="{Binding Publisher}" Style="{StaticResource Caption}"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="240" />
                                            <TextBlock Text="·" Style="{StaticResource Caption}" Margin="6,0"
                                                       Visibility="{Binding Version, Converter={StaticResource StrToVis}}" />
                                            <TextBlock Text="{Binding Version}" Style="{StaticResource Caption}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Badge residuos -->
                                    <Border Grid.Column="2" Style="{StaticResource Badge}" VerticalAlignment="Center" Margin="8,0"
                                            Visibility="{Binding HasResidualFiles, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Residuos" FontSize="11" Foreground="{StaticResource AccentDangerBrush}" />
                                    </Border>

                                    <!-- Tamaño -->
                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding EstimatedSizeMB, StringFormat={}{0} MB}" Style="{StaticResource Body}"
                                                   HorizontalAlignment="Right" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding InstallDate, StringFormat=d}" Style="{StaticResource Caption}"
                                                   HorizontalAlignment="Right" Margin="0,3,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
