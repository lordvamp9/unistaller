<Application x:Class="CleanWipe.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CleanWipe.App.ViewModels"
             xmlns:views="clr-namespace:CleanWipe.App.Views"
             xmlns:conv="clr-namespace:CleanWipe.App.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Colors.xaml" />
                <ResourceDictionary Source="Styles/Typography.xaml" />
                <ResourceDictionary Source="Styles/Buttons.xaml" />
                <ResourceDictionary Source="Styles/Cards.xaml" />
                <ResourceDictionary Source="Styles/ProgressBar.xaml" />
                <ResourceDictionary Source="Styles/Animations.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ════════════ Converters ════════════ -->
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:InverseBooleanConverter x:Key="InvBool" />
            <conv:StringToVisibilityConverter x:Key="StrToVis" />
            <conv:CountToVisibilityConverter x:Key="CountToVis" />
            <conv:EqualityToBoolConverter x:Key="EqToBool" />
            <conv:TraceTypeToIconConverter x:Key="TraceIcon" />
            <conv:TraceTypeToLabelConverter x:Key="TraceLabel" />

            <!-- ════════════ Mapeo ViewModel → View ════════════ -->
            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <views:DashboardView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:PreScanViewModel}">
                <views:PreScanView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ProgressViewModel}">
                <views:ProgressView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ResultViewModel}">
                <views:ResultView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:OrphanScanViewModel}">
                <views:OrphanScanView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
