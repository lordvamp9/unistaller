<Window x:Class="CleanWipe.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:CleanWipe.App.ViewModels"
        Title="CleanWipe" Height="720" Width="1180"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="52" ResizeBorderThickness="8" GlassFrameThickness="0" CornerRadius="0" />
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="RootBorder" CornerRadius="16" Background="{StaticResource WindowBackgroundBrush}"
            BorderBrush="#F0FFFFFF" BorderThickness="1.5" RenderTransformOrigin="0.5,0.5">
        <Border.Effect>
            <DropShadowEffect Color="#1E3A66" BlurRadius="30" ShadowDepth="4" Direction="270" Opacity="0.25" />
        </Border.Effect>
        <Border.Resources>
            <!-- Patrón de puntos sutil para el fondo -->
            <DrawingBrush x:Key="DotGrid" TileMode="Tile"
                          Viewport="0,0,26,26" ViewportUnits="Absolute"
                          Viewbox="0,0,26,26" ViewboxUnits="Absolute" Opacity="0.55">
                <DrawingBrush.Drawing>
                    <GeometryDrawing Brush="#A9C4E1">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="2,2" RadiusX="1.4" RadiusY="1.4" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingBrush.Drawing>
            </DrawingBrush>
        </Border.Resources>

        <Grid x:Name="ContentRoot" SizeChanged="ContentRoot_SizeChanged">

            <!-- ════════════ Capa "liquid glass": auras de color difuminadas ════════════ -->
            <Canvas IsHitTestVisible="False">
                <Ellipse Canvas.Left="-160" Canvas.Top="-180" Width="560" Height="480" Opacity="0.55">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#7A6FD2FF" Offset="0" />
                            <GradientStop Color="#006FD2FF" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Ellipse Canvas.Right="0" Width="620" Height="520" Opacity="0.5" Canvas.Top="-140">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#663D8BFF" Offset="0" />
                            <GradientStop Color="#003D8BFF" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Ellipse Canvas.Left="220" Canvas.Bottom="-220" Width="640" Height="500" Opacity="0.45">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#5C00C896" Offset="0" />
                            <GradientStop Color="#0000C896" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
            </Canvas>

            <!-- Grid de puntos sobre las auras -->
            <Border Background="{StaticResource DotGrid}" IsHitTestVisible="False" />

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="52" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- ════════════ Barra de título personalizada ════════════ -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                        <Image Source="/Assets/icon.ico" Width="26" Height="26" />
                        <TextBlock Text="CleanWipe" FontFamily="{StaticResource DisplayFont}" FontWeight="Bold"
                                   FontSize="16" Foreground="{StaticResource TextPrimaryBrush}" Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                        <Border Background="#261E6FFF" CornerRadius="6" Padding="7,2" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="v1.1" FontSize="11" Foreground="{StaticResource AccentPrimaryBrush}" FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>

                    <!-- Botones de ventana -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button x:Name="MinButton" Style="{StaticResource CaptionButton}" Content="&#xE921;" Click="Minimize_Click" />
                        <Button x:Name="MaxButton" Style="{StaticResource CaptionButton}" Content="&#xE922;" Click="Maximize_Click" />
                        <Button x:Name="CloseButton" Style="{StaticResource CloseCaptionButton}" Content="&#xE8BB;" Click="Close_Click" />
                    </StackPanel>
                </Grid>

                <!-- ════════════ Cuerpo: rail de navegación + contenido ════════════ -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="210" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Rail (glass blanco translúcido) -->
                    <Border Grid.Column="0" Background="#8CFFFFFF" BorderBrush="#A6FFFFFF"
                            BorderThickness="0,1,1.5,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="NAVEGACIÓN" Style="{StaticResource Caption}"
                                       Margin="24,18,0,8" FontWeight="SemiBold" />
                            <StackPanel DockPanel.Dock="Top">
                                <RadioButton Style="{StaticResource NavButton}" Content="Programas" Tag="&#xE71D;"
                                             GroupName="nav" Command="{Binding GoDashboardCommand}"
                                             IsChecked="{Binding SelectedPage, Converter={StaticResource EqToBool}, ConverterParameter=Dashboard, Mode=OneWay}" />
                                <RadioButton Style="{StaticResource NavButton}" Content="Residuos Huérfanos" Tag="&#xE74C;"
                                             GroupName="nav" Command="{Binding GoOrphansCommand}"
                                             IsChecked="{Binding SelectedPage, Converter={StaticResource EqToBool}, ConverterParameter=Orphans, Mode=OneWay}" />
                                <RadioButton Style="{StaticResource NavButton}" Content="Ajustes" Tag="&#xE713;"
                                             GroupName="nav" Command="{Binding GoSettingsCommand}"
                                             IsChecked="{Binding SelectedPage, Converter={StaticResource EqToBool}, ConverterParameter=Settings, Mode=OneWay}" />
                            </StackPanel>

                            <!-- Firma vamp9 al pie -->
                            <StackPanel DockPanel.Dock="Bottom" Margin="24,0,0,18" VerticalAlignment="Bottom">
                                <TextBlock Text="hecho por" Style="{StaticResource Caption}" />
                                <TextBlock Text="vamp9" FontFamily="{StaticResource DisplayFont}" FontWeight="Bold"
                                           FontSize="15" Foreground="{StaticResource AccentPrimaryBrush}" />
                            </StackPanel>
                            <Grid />
                        </DockPanel>
                    </Border>

                    <!-- Contenido (vista actual) -->
                    <ContentControl Grid.Column="1" Content="{Binding Navigation.CurrentViewModel}" Margin="0" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
