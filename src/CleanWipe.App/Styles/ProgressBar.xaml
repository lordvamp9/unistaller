<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════ Barra de progreso con shimmer y glow ════════════ -->
    <Style x:Key="GlowProgressBar" TargetType="ProgressBar">
        <Setter Property="Height" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource AccentPrimaryBrush}" />
        <Setter Property="Background" Value="#D9E7F6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border CornerRadius="7" Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" ClipToBounds="True">
                        <Grid>
                            <Border x:Name="PART_Track" />
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="7">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#1E6FFF" Offset="0" />
                                        <GradientStop Color="#3D8BFF" Offset="0.5" />
                                        <GradientStop Color="#00C896" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#1E6FFF" BlurRadius="18" ShadowDepth="0" Opacity="0.7" />
                                </Border.Effect>
                                <!-- Brillo que recorre la barra (shimmer) -->
                                <Border x:Name="shimmer" CornerRadius="7" Width="60" HorizontalAlignment="Left">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00FFFFFF" Offset="0" />
                                            <GradientStop Color="#55FFFFFF" Offset="0.5" />
                                            <GradientStop Color="#00FFFFFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="shimmerT" X="-60" />
                                    </Border.RenderTransform>
                                </Border>
                            </Border>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="shimmerT" Storyboard.TargetProperty="X"
                                                     From="-60" To="400" Duration="0:0:1.4" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
